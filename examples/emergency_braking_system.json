  <ownedRequirements>
    <requirement id="SYS-001" name="SYS-001" description="System shall detect obstacles up to 150m ahead" priority="Critical" />
    <requirement id="SYS-002" name="SYS-002" description="System shall initiate braking within 100ms of obstacle detection" priority="Critical" />
    <requirement id="SYS-003" name="SYS-003" description="False positive rate shall be less than 1 in 10^9 operating hours" priority="Critical" />
    <requirement id="SYS-004" name="SYS-004" description="System shall fuse data from at least 3 sensor types" priority="High" />
    <requirement id="SYS-005" name="SYS-005" description="System shall maintain basic functionality with one sensor failure" priority="High" />
    <requirement id="SYS-006" name="SYS-006" description="Driver shall be able to override system at any time" priority="High" />
    <requirement id="SYS-007" name="SYS-007" description="System shall continuously monitor and report its status" priority="Medium" />
  </ownedRequirements>
