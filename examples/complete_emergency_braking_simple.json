  <ownedRequirements>
    <requirement id="REQ-AEB-001" name="REQ-AEB-001" description="The system shall detect obstacles at a range of at least 150 m" priority="High" />
    <requirement id="REQ-AEB-002" name="REQ-AEB-002" description="Radar and camera data shall be fused within 50 ms" priority="High" />
    <requirement id="REQ-AEB-003" name="REQ-AEB-003" description="The system shall compute time-to-collision for every tracked object" priority="High" />
    <requirement id="REQ-AEB-004" name="REQ-AEB-004" description="Full braking force shall be commanded within 100 ms of critical threat detection" priority="High" />
    <requirement id="REQ-AEB-005" name="REQ-AEB-005" description="The driver shall be warned before autonomous braking is applied" priority="Medium" />
  </ownedRequirements>
